import pandas as pd
import numpy as np
from sklearn.metrics import precision_score, recall_score, f1_score, roc_auc_score
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score
from sklearn.linear_model import LinearRegression

def run_clous_operational_diagnostics(csv_path):
    # 1. Load your final dataset
    df = pd.read_csv(csv_path)

    # Standardize column names based on typical pipeline outputs
    clous_col = 'clous_score'
    fertility_col = 'fertility_score'

    print("=== 1. High-Risk Entity Classification ===")
    # Define "High Risk" as the top 25% of actual fertility fragmentation
    fertility_threshold = df[fertility_col].quantile(0.75)
    df['actual_high_risk'] = (df[fertility_col] >= fertility_threshold).astype(int)

    # We predict "High Risk" if the CLOUS score is in the top 25%
    clous_threshold = df[clous_col].quantile(0.75)
    df['predicted_high_risk'] = (df[clous_col] >= clous_threshold).astype(int)

    # Calculate classification metrics
    roc_auc = roc_auc_score(df['actual_high_risk'], df[clous_col])
    precision = precision_score(df['actual_high_risk'], df['predicted_high_risk'])
    recall = recall_score(df['actual_high_risk'], df['predicted_high_risk'])
    f1 = f1_score(df['actual_high_risk'], df['predicted_high_risk'])

    print(f"ROC-AUC:   {roc_auc:.3f}")
    print(f"Precision: {precision:.3f}")
    print(f"Recall:    {recall:.3f}")
    print(f"F1 Score:  {f1:.3f}\n")

    print("=== 2. Quartile-Based Risk Stratification ===")
    # Group CLOUS scores into four quartiles
    df['clous_quartile'] = pd.qcut(df[clous_col], q=4, labels=['Q1', 'Q2', 'Q3', 'Q4'])
    quartile_means = df.groupby('clous_quartile')[fertility_col].mean()

    for q in ['Q1', 'Q2', 'Q3', 'Q4']:
        print(f"{q} Mean Fertility: {quartile_means[q]:.3f}")

    pct_increase = ((quartile_means['Q4'] - quartile_means['Q1']) / quartile_means['Q1']) * 100
    print(f"Fragmentation Increase (Q1 to Q4): {pct_increase:.1f}%\n")

    print("=== 3. Simple Predictive Regression ===")
    X = df[[clous_col]]
    y = df[fertility_col]

    model = LinearRegression()
    model.fit(X, y)
    y_pred = model.predict(X)

    r2 = r2_score(y, y_pred)
    mae = mean_absolute_error(y, y_pred)
    rmse = np.sqrt(mean_squared_error(y, y_pred))

    print(f"R-squared (R2): {r2:.3f}")
    print(f"MAE:            {mae:.3f}")
    print(f"RMSE:           {rmse:.3f}")
    print(f"Linear Eq:      Fertility = {model.intercept_:.3f} + {model.coef_[0]:.3f} * CLOUS")

